{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "MultiEdit(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(sudo rm*)",
      "Bash(sudo chmod -R 777*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(curl * | bash*)",
      "Bash(wget * | bash*)",
      "Bash(* > /dev/sda*)",
      "Bash(dd if=*)",
      "Bash(mkfs*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/admin/causticsEngineering/.claude/hooks/check_julia_direct.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/admin/causticsEngineering/.claude/hooks/check_focal_sync.sh"
          }
        ]
      }
    ]
  }
}
